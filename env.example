# Netlify → Site settings → Environment variables (never commit real secrets)

STRIPE_SECRET_KEY=sk_test_...

# Optional overrides (defaults are your current Price IDs)
STRIPE_PRICE_PACK=price_1TVxEXFvdwbjRSVAwdGPdqgk
STRIPE_PRICE_MONTHLY=price_1TVxG3FvdwbjRSVAf6no1Tx7

# Netlify sets URL on deploy. Local: netlify dev → http://localhost:8888

# Demo (no Stripe): add ?demo=1 or ?demo or ?demo=true to the URL (also skips Stripe return_url verify). Turn off with ?demo=0. Pack button: ~1s loading then +10 credits + result popup.
